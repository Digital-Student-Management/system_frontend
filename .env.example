# Variables de entorno del GED Frontend
# Copia este archivo como .env y ajusta los valores para tu entorno.
# NUNCA subas el archivo .env real al repositorio.

# URL base de la API del backend (Spring Boot)
# En desarrollo, Vite usa el proxy de vite.config.js si no se define esta variable.
VITE_API_URL=http://localhost:8080/api

# Nombre de la aplicación (opcional, para mostrar en el título)
VITE_APP_NAME=Colegio Bernardo O'Higgins
